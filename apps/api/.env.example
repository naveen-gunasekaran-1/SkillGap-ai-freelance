# Local dev (SQLite). For production, use PostgreSQL + `docker-compose.yml`.
DATABASE_URL="file:./dev.db"

# Must be >= 32 characters in production
JWT_ACCESS_SECRET=change_me_access_token_secret_32chars_min
JWT_REFRESH_SECRET=change_me_refresh_token_secret_32chars_min

JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8081,http://127.0.0.1:8081

PORT=3001

# Optional
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
