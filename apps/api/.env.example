# PostgreSQL connection string. Render production should use the Render Postgres internal URL.
DATABASE_URL="postgresql://skillgap:skillgap@localhost:5432/skillgap"

# Must be >= 32 characters in production.
JWT_ACCESS_SECRET=change_me_access_token_secret_32chars_min
JWT_REFRESH_SECRET=change_me_refresh_token_secret_32chars_min

JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

CORS_ORIGINS=https://skillgap-ai-career.netlify.app,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8081,http://127.0.0.1:8081

PORT=3001
APP_URL=https://skillgap-ai-career.netlify.app
API_URL=https://skillgap-ai-freelance.onrender.com
MOBILE_APP_URL=skillgapai://oauth/callback

# OAuth login. Add these callback URLs in each provider console:
# Google:   https://skillgap-ai-freelance.onrender.com/api/auth/oauth/google/callback
# LinkedIn: https://skillgap-ai-freelance.onrender.com/api/auth/oauth/linkedin/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=

# Temporary debugging only. Set to false or remove after fixing production.
# EXPOSE_ERROR_DETAILS=false

# Optional AI enrichment.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Email. Resend is the recommended free-tier transactional provider for this project.
# If RESEND_API_KEY is empty in development, reset/verification links are logged by the API.
# RESEND_API_KEY=
# EMAIL_FROM="SkillGap AI <no-reply@yourdomain.com>"
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=

# Cloudflare R2 / S3-compatible storage for resumes and verification documents.
# R2 endpoint format: https://<account_id>.r2.cloudflarestorage.com
# S3_PUBLIC_URL is optional for public resume URLs. Verification documents remain private.
# S3_ENDPOINT=
# S3_REGION=auto
# S3_BUCKET=skillgap-ai
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC_URL=
